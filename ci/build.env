# CI pins — sync with workflow_dispatch defaults in .github/workflows/build.yml

JAVA_VERSION=17

MC_VERSION=1.20.1
MC_ASSET_INDEX=5
FORGE_BUILD=47.4.13

HMC_VERSION=2.9.0
MODPACK_DIR=Modpack-Modern
MODPACK_REPO=https://github.com/TerraFirmaGreg-Team/Modpack-Modern.git

# GitHub Release jars (jmecn/*)
FGE_VERSION=v0.1.7
MWE_VERSION=v0.5.4
# Export locales: derived at CI from :core Language enum (scripts/ci-resolve-export-languages.sh)
# → -Dfieldguide.exportLanguages=... on the game JVM

EXPORT_WARMUP_TICKS=100
EXPORT_WORLD_DELAY_TICKS=600
EXPORT_TIMEOUT_SECONDS=7200
FIELDGUIDE_EXPORT_MODE=full

# minecraft-web-export output root (guide-export/ + emi/ siblings)
EXPORT_ROOT_DIR=export
GUIDE_SUBDIR=guide-export
SITE_OUTPUT_DIR=output

# EMI slot / tag popover links → ?lang=&item= or &tag= on this base (override when domain moves)
RECIPE_BOOK_BASE_URL=https://www.jmecn.net/TFG-Recipe-Viewer/

RUNNER_HOME=/home/runner
